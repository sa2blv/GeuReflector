###################################################################
#
# Configuration file for the SvxReflector SvxLink conference node
#
###################################################################

[GLOBAL]
#CFG_DIR=svxreflector.d
TIMESTAMP_FORMAT="%c"
LISTEN_PORT=5300
#SQL_TIMEOUT=600
#SQL_TIMEOUT_BLOCKTIME=60
#CODECS=OPUS
TG_FOR_V1_CLIENTS=999
#LOCAL_PREFIX=1
#CLUSTER_TGS=222,2221,91
#RANDOM_QSY_RANGE=12399:100
#HTTP_SRV_PORT=8080
COMMAND_PTY=/dev/shm/reflector_ctrl
#ACCEPT_CALLSIGN="[A-Z0-9][A-Z]{0,2}\\d[A-Z0-9]{0,3}[A-Z](?:-[A-Z0-9]{1,3})?"
#REJECT_CALLSIGN=""
#ACCEPT_CERT_EMAIL="\\w+(?:[-._+]\\w+)*@\\w+(?:\\.\\w+)*"
#CERT_PKI_DIR=pki/
#CERT_CA_BUNDLE=ca-bundle.crt
#CERT_CA_KEYS_DIR=private/
#CERT_CA_PENDING_CSRS_DIR=pending_csrs/
#CERT_CA_CSRS_DIR=csrs/
#CERT_CA_CERTS_DIR=certs/
CERT_CA_HOOK=@SVX_SHARE_INSTALL_DIR@/ca-hook.py

[ROOT_CA]
#KEYFILE=svxreflector_root_ca.key
#CRTFILE=svxreflector_root_ca.crt
#COMMON_NAME=SvxReflector Root CA
#ORG_UNIT=SvxLink
#ORG=MyOrg
#LOCALITY=MyTown
#STATE=StateOrProvince
#COUNTRY=XX
#EMAIL_ADDRESS=sysop@svxlink.example.org

[ISSUING_CA]
#KEYFILE=svxreflector_issuing_ca.key
#CSRFILE=svxreflector_issuing_ca.csr
#CRTFILE=svxreflector_issuing_ca.crt
#COMMON_NAME=SvxReflector Issuing CA
#ORG_UNIT=SvxLink
#ORG=MyOrg
#LOCALITY=MyTown
#STATE=StateOrProvince
#COUNTRY=XX
#EMAIL_ADDRESS=sysop@svxlink.example.org

[SERVER_CERT]
#KEYFILE=svxreflector.key
#CSRFILE=svxreflector.csr
#CRTFILE=svxreflector.crt
#COMMON_NAME=svxreflector.example.org
#ORG_UNIT=SvxLink
#ORG=MyOrg
#LOCALITY=MyTown
#STATE=StateOrProvince
#COUNTRY=XX
#SUBJECT_ALT_NAME=DNS:public-hostname.example.org,IP:172.17.1.42
#EMAIL_ADDRESS=sysop@svxlink.example.org

[USERS]
#SM0ABC-1=MyNodes
#SM0ABC-2=MyNodes
#SM3XYZ=SM3XYZ

[PASSWORDS]
#MyNodes="Change this key now!"
#SM3XYZ="A strong password"

#[TG#9999]
#AUTO_QSY_AFTER=300
#ALLOW=S[A-M]\\\\d.*|LA8PV
#ALLOW_MONITOR=S[A-M]3.*
#SHOW_ACTIVITY=0

# Trunk links to peer SvxReflector instances (prefix-based TG routing).
#
# Each reflector owns all TGs whose decimal representation starts with
# LOCAL_PREFIX. For example, LOCAL_PREFIX=1 means this reflector is
# authoritative for TGs 1, 10, 100, 1000, 12345, etc.
#
# Add LOCAL_PREFIX to the [GLOBAL] section, then add one [TRUNK_x] section
# per peer. REMOTE_PREFIX declares which TG prefix the peer owns.
#
# IMPORTANT: The [TRUNK_x] section name must be identical on both sides.
# Both sysops must agree on a shared name and secret for each link.
#
# Example for a two-reflector mesh:
#   Reflector A: LOCAL_PREFIX=1, [TRUNK_AB] with REMOTE_PREFIX=2
#   Reflector B: LOCAL_PREFIX=2, [TRUNK_AB] with REMOTE_PREFIX=1
#
#LOCAL_PREFIX=1
#TRUNK_LISTEN_PORT=5302
#TRUNK_DEBUG=0              # verbose trunk logging (high log volume — disable after diagnosis)

#[TRUNK_AB]
#HOST=reflector-b.example.com
#PORT=5302
#SECRET=change_this_shared_secret
#REMOTE_PREFIX=2
# Optional PEER_ID — name advertised to the peer in the trunk hello
# (defaults to section name). The peer uses it as the MQTT topic
# component for this link, so set it to a stable, broker-friendly name.
#PEER_ID=reflector-a
# Optional per-trunk TG filters (syntax: exact "26200", prefix "24*",
# range "2427-2438", comma-separated):
#BLACKLIST_TGS=666,777*       # never carried in either direction on this link
#ALLOW_TGS=24*,2624123        # if set, ONLY these TGs are exchanged
# Optional bidirectional TG remap (peer_tg:local_tg, comma-separated).
# Mapped TGs bypass the prefix routing check on this link.
#TG_MAP=1:2624123,2:2624124

# --- Satellite reflectors ---
# A satellite is a lightweight reflector that connects to a parent
# reflector instead of joining the trunk mesh. Clients connect to the
# satellite normally; it relays everything to the parent.
#
# Parent side: accept inbound satellite connections
#[SATELLITE]
#LISTEN_PORT=5303
#SECRET=change_this_satellite_secret
#
# Satellite side: set these in [GLOBAL] instead of LOCAL_PREFIX/TRUNK_x
#SATELLITE_OF=reflector-01.example.com
#SATELLITE_PORT=5303
#SATELLITE_SECRET=change_this_satellite_secret
#SATELLITE_ID=my-satellite

#
# MQTT publishing. Optional — omit this section to disable.
# Publishes real-time events (talker, client, trunk state) and periodic
# full status to an external MQTT broker.
#
# All fields except TLS and STATUS_INTERVAL are required when this
# section is present. TOPIC_PREFIX has no default — set it to a unique
# identifier for this reflector (e.g. svxreflector/myreflector).
#
#[MQTT]
#HOST=mqtt.example.com
#PORT=1883
#USERNAME=reflector
#PASSWORD=secret
#TOPIC_PREFIX=svxreflector/myreflector
# Optional MQTT_NAME — appended as a path component, so topics become
# <TOPIC_PREFIX>/<MQTT_NAME>/... — useful when several reflectors share
# the same TOPIC_PREFIX. Leave unset to keep topics flat.
#MQTT_NAME=reflector-01
#STATUS_INTERVAL=1000
#TLS_ENABLED=0
#TLS_CA_CERT=/path/to/ca.crt
#TLS_CLIENT_CERT=/path/to/client.crt
#TLS_CLIENT_KEY=/path/to/client.key

#
# Redis-backed config store. Optional — omit this section to use the
# config-file-only behavior. When this section is present, [USERS],
# [PASSWORDS], CLUSTER_TGS, and per-trunk BLACKLIST_TGS / ALLOW_TGS /
# TG_MAP / mute lists are read from Redis instead of this file. Use
# `svxreflector --import-conf-to-redis` once to migrate existing entries.
#
#[REDIS]
#HOST=127.0.0.1
#PORT=6379
#PASSWORD=
#DB=0
#KEY_PREFIX=
#UNIX_SOCKET=             # if set, takes precedence over HOST/PORT
#TLS_ENABLED=0
#TLS_CA_CERT=
#TLS_CLIENT_CERT=
#TLS_CLIENT_KEY=

